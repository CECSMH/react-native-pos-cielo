{
  "name": "react-native-pos-cielo",
  "version": "1.0.0",
  "description": "Integration of Cielo POS features for React Native",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "react-native-pos-cielo-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-pos-cielo-example",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepublishOnly": "bob build",
    "typecheck": "tsc"
  },
  "keywords": [
    "react-native",
    "cielo",
    "cielo-lio",
    "cielo-smart",
    "pos",
    "pos-terminal",
    "payment",
    "payments",
    "pagamento",
    "pagamentos",
    "pix",
    "credit-card",
    "debit-card",
    "cartao",
    "receipt",
    "receipt-printer",
    "thermal-printer",
    "print",
    "impressao",
    "turbo-module",
    "new-architecture",
    "deeplink",
    "android",
    "brazil",
    "fintech"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CECSMH/react-native-pos-cielo.git"
  },
  "author": "CECSMH (https://github.com/CECSMH)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CECSMH/react-native-pos-cielo/issues"
  },
  "homepage": "https://github.com/CECSMH/react-native-pos-cielo#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@react-native/jest-preset": "0.85.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-builder-bob": "^0.41.0",
    "react-native-web": "~0.21.2",
    "release-it": "^20.2.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "PosCieloSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.poscielo"
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": {
          "name": "angular"
        }
      }
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint",
      "jest",
      "lefthook",
      "release-it",
      "vite"
    ],
    "version": "0.63.0"
  }
}
